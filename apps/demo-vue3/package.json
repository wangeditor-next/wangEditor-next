    "@wangeditor-next/editor-for-vue": "latest",
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^2.3.4",
    "typescript": "~4.5.5",
    "vite": "^2.9.16",
    "vue-tsc": "1.0.24"
  }
}
