{
  "name": "@wangeditor-next/demo-yjs-react",
  "version": "0.0.7",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:server": "pnpm exec y-websocket --port 1234 --path /wangeditor-next-yjs",
    "dev:all": "pnpm exec concurrently \"pnpm --dir ../../packages/editor dev-watch\" \"pnpm --dir ../../packages/editor-for-react dev-watch\" \"pnpm --dir ../../packages/yjs dev-watch\" \"pnpm --dir ../../packages/yjs-for-react dev-watch\" \"pnpm run dev:server\" \"pnpm run dev\"",
    "build": "vite build",
    "smoke": "pnpm --dir ../.. exec turbo build --filter=@wangeditor-next/demo-yjs-react"
  },
  "dependencies": {
    "@faker-js/faker": "^7.5.0",
    "@fortawesome/fontawesome-svg-core": "^1.3.0",
    "@fortawesome/free-regular-svg-icons": "^6.0.0",
    "@fortawesome/free-solid-svg-icons": "^6.0.0",
    "@fortawesome/react-fontawesome": "^0.1.17",
    "@wangeditor-next/editor": "workspace:*",
    "@wangeditor-next/editor-for-react": "workspace:*",
    "@wangeditor-next/yjs": "workspace:*",
    "@wangeditor-next/yjs-for-react": "workspace:*",
    "clsx": "^1.1.1",
    "randomcolor": "^0.6.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^6.0.1",
    "vite-plugin-windicss": "1.9.3",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.19"
  },
  "devDependencies": {
    "@types/randomcolor": "^0",
    "@types/react": "^17.0.34",
    "@types/react-dom": "^17.0.11",
    "@vitejs/plugin-react": "^1.0.7",
    "autoprefixer": "^10.4.0",
    "vite": "^2.6.13",
    "windicss": "^3.5.1"
  }
}
