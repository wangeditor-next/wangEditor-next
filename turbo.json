{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.json",
    "shared/rollup-config/**"
  ],
  "tasks": {
    "dev": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "rollup.config.js",
        "tsconfig.json",
        "package.json"
      ],
      "dependsOn": [
        "^dev"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "build": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "rollup.config.js",
        "tsconfig.json",
        "package.json"
      ],
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "example": {
      "persistent": true,
      "cache": false
    }
  }
}
